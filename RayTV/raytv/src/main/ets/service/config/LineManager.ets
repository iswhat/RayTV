
import { Site } from '../../data/bean/Site';
import { SiteManager } from '../spider/SiteManager';
import { ConfigLoader } from './ConfigLoader';
import { ConfigParser } from './ConfigParser';
import { SiteDao } from '../../data/db/dao/SiteDao';
import { LineDao } from '../../data/db/dao/LineDao';
import http from '@ohos.net.http';
import common from '@ohos.app.ability.common';

const TAG = 'LineManager';

/**
 * зәҝи·Ҝй…ҚзҪ®жҺҘеҸЈ | Line configuration interface
 */
export interface LineItem {
  id: string;              // е”ҜдёҖж ҮиҜҶ | Unique identifier
  name: string;            // зәҝи·ҜеҗҚз§° | Line name
  url: string;             // зәҝи·ҜURL | Line URL
  description?: string;    // зәҝи·ҜжҸҸиҝ° | Line description
  type?: 'all' | 'vod' | 'live'; // зәҝи·Ҝзұ»еһӢ | Line type
  updateTime: number;      // жңҖеҗҺжӣҙж–°ж—¶й—?| Last update time
  createTime: number;      // еҲӣе»әж—¶й—ҙ | Create time
  sourceCount: number;     // еҢ…еҗ«жәҗж•°йҮ?| Number of sources
  enabled: boolean;        // жҳҜеҗҰеҗҜз”Ё | Whether enabled
  current: boolean;        // жҳҜеҗҰдёәеҪ“еүҚдҪҝз”Ёзҡ„зәҝи·Ҝ | Whether it is the currently used line
  cacheTime?: number;      // зј“еӯҳж—¶й—ҙпјҲе°Ҹж—¶пјү | Cache time (hours)
  responseTime?: number;   // е“Қеә”ж—¶й—ҙпјҲжҜ«з§’пјү | Response time (milliseconds)
}

/**
 * жәҗе“Қеә”жөӢиҜ•з»“жһ?| Source response test result
 */
export interface SourceResponseResult {
  sourceId: string;
  sourceName: string;
  responseTime: number;    // е“Қеә”ж—¶й—ҙпјҲжҜ«з§’пјү | Response time (milliseconds)
  success: boolean;
  error?: string;
}

/**
 * зәҝи·Ҝе“Қеә”жөӢиҜ•з»“жһң | Line response test result
 */
export interface LineResponseResult {
  lineId: string;
  lineName: string;
  responseTime: number;    // е“Қеә”ж—¶й—ҙпјҲжҜ«з§’пјү | Response time (milliseconds)
  success: boolean;
  error?: string;
  sourceResults?: SourceResponseResult[];
}

/**
 * зәҝи·Ҝз®ЎзҗҶз»“жһң | Line management result
 */
export interface LineResult {
  success: boolean;
  message?: string;
  data?: LineResultData;
}

/**
 * зәҝи·Ҝз®ЎзҗҶз»“жһңж•°жҚ®жҺҘеҸЈ | Line management result data interface
 */
export interface LineResultData {
  line?: LineItem;
  sites?: Site[];
  responseTime?: number;
  id?: string;
  name?: string;
  url?: string;
  description?: string;
  type?: string;
  updateTime?: number;
  createTime?: number;
  sourceCount?: number;
  enabled?: boolean;
  current?: boolean;
  cacheTime?: number;
}

/**
 * зәҝи·Ҝз®ЎзҗҶеҷ?| Line manager
 * иҙҹиҙЈй…ҚзҪ®URLзҡ„зәҝи·Ҝз®ЎзҗҶгҖҒжӣҙж–°е’ҢеҲҮжҚў | Responsible for line management, update and switching of configuration URLs
 */
export class LineManager {
  private static instance: LineManager | null = null;
  private lines: Map<string, LineItem> = new Map();
  private initialized: boolean = false;
  private context?: common.UIAbilityContext;
  
  // й»ҳи®Өзј“еӯҳж—¶й—ҙй…ҚзҪ®
  private defaultCacheHours: number = 24; // й»ҳи®Ө24е°Ҹж—¶ | Default 24 hours
  private minCacheHours: number = 24;     // жңҖе°?4е°Ҹж—¶ | Minimum 24 hours
  private maxCacheHours: number = 72;     // жңҖеӨ?2е°Ҹж—¶ | Maximum 72 hours

  /**
   * иҺ·еҸ–еҚ•дҫӢе®һдҫӢ | Get singleton instance
   */
  public static getInstance(): LineManager {
    if (!LineManager.instance) {
      LineManager.instance = new LineManager();
    }
    return LineManager.instance;
  }
  
  /**
   * жһ„йҖ еҮҪж•?| Constructor
   */
  private constructor() {
    console.info(TAG + ': LineManager initialized');
  }

  /**
   * и®ҫзҪ®зј“еӯҳж—¶й—ҙиҢғеӣҙ | Set cache time range
   * @param minHours жңҖе°Ҹзј“еӯҳж—¶й—ҙпјҲе°Ҹж—¶пј?| Minimum cache time (hours)
   * @param maxHours жңҖеӨ§зј“еӯҳж—¶й—ҙпјҲе°Ҹж—¶пј?| Maximum cache time (hours)
   */
  public setCacheTimeRange(minHours: number, maxHours: number): void {
    this.minCacheHours = Math.max(24, minHours);
    this.maxCacheHours = Math.min(72, Math.max(this.minCacheHours, maxHours));
    console.info(TAG + `: Cache time range set to ${this.minCacheHours}-${this.maxCacheHours} hours`);
  }

  /**
   * еҲқе§ӢеҢ–зәҝи·Ҝз®ЎзҗҶеҷЁ | Initialize line manager
   * @param context еә”з”ЁдёҠдёӢж–?| Application context
   */
  public async initialize(context?: common.UIAbilityContext): Promise<void> {
    if (this.initialized) {
      return;
    }

    try {
      // дҝқеӯҳдёҠдёӢж–ҮпјҲеҰӮжһңжҸҗдҫӣпј?| Save context (if provided)
      if (context) {
        this.context = context;
      }
      
      console.info(TAG + ': Initializing line manager...');
      
      // еҲқе§ӢеҢ–зәҝи·ҜиЎЁ | Initialize line table
      await new LineDao().initTable(context);
      
      // д»ҺжҢҒд№…еҢ–еӯҳеӮЁеҠ иҪҪзәҝи·Ҝй…ҚзҪ® | Load line config from persistent storage
      await this.loadLines();
      
      // жҒўеӨҚеҪ“еүҚзәҝи·Ҝзҡ„жәҗ | Restore sources for current line
      const currentLine = this.getCurrentLine();
      if (currentLine && currentLine.enabled) {
        console.info(TAG + `: Restoring sources for current line: ${currentLine.name}`);
        try {
          // еҠ иҪҪй…ҚзҪ®е№¶жіЁеҶҢжәҗ | Load config and register sources
          const configContent = await ConfigLoader.getInstance().loadFromUrl(currentLine.url);
          const sites = ConfigParser.getInstance().parseSites(configContent);
          await SiteManager.getInstance().registerSites(sites);
        } catch (error) {
          console.error(TAG + `: Failed to restore current line sources`, error instanceof Error ? error : new Error(String(error)));
        }
      }
      
      this.initialized = true;
      console.info(TAG + `: Line manager initialized with ${this.lines.size} lines`);
    } catch (error) {
      console.error(TAG + `: Failed to initialize line manager`, error);
      throw error;
    }
  }

  /**
   * ж·»еҠ зәҝи·Ҝ | Add line
   * @param name зәҝи·ҜеҗҚз§° | Line name
   * @param url зәҝи·ҜURL | Line URL
   * @param description зәҝи·ҜжҸҸиҝ° | Line description
   * @param cacheTime зј“еӯҳж—¶й—ҙпјҲе°Ҹж—¶пјү | Cache time (hours)
   */
  public async addLine(name: string, url: string, description?: string, cacheTime?: number): Promise<LineResult> {
    try {
      // йӘҢиҜҒURLж јејҸ | Validate URL format
      if (!this.isValidUrl(url)) {
        return {
          success: false,
          message: 'ж— ж•Ҳзҡ„URLж јејҸ' 
        };
      }

      // йӘҢиҜҒе№¶и§„иҢғеҢ–зј“еӯҳж—¶й—ҙ | Validate and normalize cache time
      const normalizedCacheTime = this.normalizeCacheTime(cacheTime);

      // з”ҹжҲҗзәҝи·ҜID | Generate line ID
      const id = this.generateLineId(url);
      
      // жЈҖжҹҘжҳҜеҗҰе·ІеӯҳеңЁзӣёеҗҢURLзҡ„зәҝи·?| Check if line with same URL already exists
      if (this.lines.has(id)) {
        return {
          success: false,
          message: 'зәҝи·ҜURLе·Іеӯҳең?
        };
      }

      // жөӢиҜ•зәҝи·ҜURLжҳҜеҗҰеҸҜи®ҝй—?| Test if line URL is accessible
      const testResult = await this.testLineUrl(url);
      if (!testResult.success) {
        return testResult;
      }

      // еҲӣе»әзәҝи·ҜйЎ?| Create line item
      const line: LineItem = {
        id,
        name,
        url,
        description,
        updateTime: Date.now(),
        createTime: Date.now(),
        sourceCount: (testResult.data?.sites?.length || 0),
        enabled: true,
        current: false,
        cacheTime: normalizedCacheTime,
        responseTime: testResult.data?.responseTime
      };

      // ж·»еҠ еҲ°зәҝи·ҜеҲ—иЎ?| Add to line list
      this.lines.set(id, line);
      
      // дҝқеӯҳеҲ°жҢҒд№…еҢ–еӯҳеӮЁ | Save to persistent storage
      await this.saveLines();

      console.info(TAG + `: Added line: ${name} (${url})`);
      return {
        success: true,
        message: 'зәҝи·Ҝж·»еҠ жҲҗеҠҹ',
        data: line
      };
    } catch (error) {
      console.error(TAG + `: Failed to add line: ${error.message}`);
      return {
        success: false, 
        message: `ж·»еҠ зәҝи·ҜеӨұиҙҘ: ${error.message}`
      };
    }
  }

  /**
   * еҲ йҷӨзәҝи·Ҝ | Delete line
   * @param lineId зәҝи·ҜID | Line ID
   */
  public async deleteLine(lineId: string): Promise<LineResult> {
    try {
      const line = this.lines.get(lineId);
      if (!line) {
        return {
          success: false,
          message: 'зәҝи·ҜдёҚеӯҳең?
        };
      }

      // еҰӮжһңжҳҜеҪ“еүҚдҪҝз”Ёзҡ„зәҝи·ҜпјҢе…ҲзҰҒз”Ё | If it is the current line, disable first
      if (line.current) {
        await this.disableCurrentLine();
      }

      // д»Һзәҝи·ҜеҲ—иЎЁдёӯеҲ йҷӨ | Remove from line list
      this.lines.delete(lineId);
      
      // дҝқеӯҳеҲ°жҢҒд№…еҢ–еӯҳеӮЁ | Save to persistent storage
      await this.saveLines();

      console.info(TAG + `: Deleted line: ${line.name}`);
      return {
        success: true,
        message: 'зәҝи·ҜеҲ йҷӨжҲҗеҠҹ'
      };
    } catch (error) {
      console.error(TAG + `: Failed to delete line: ${error.message}`);
      return {
        success: false, 
        message: `еҲ йҷӨзәҝи·ҜеӨұиҙҘ: ${error.message}`
      };
    }
  }

  /**
   * жӣҙж–°зәҝи·Ҝ | Update line
   * @param lineId зәҝи·ҜID | Line ID
   * @param data жӣҙж–°ж•°жҚ® | Update data
   */
  public async updateLine(lineId: string, data: Partial<LineItem>): Promise<LineResult> {
    try {
      const line = this.lines.get(lineId);
      if (!line) {
        return {
          success: false,
          message: 'зәҝи·ҜдёҚеӯҳең?
        };
      }

      // йӘҢиҜҒе№¶и§„иҢғеҢ–зј“еӯҳж—¶й—ҙпјҲеҰӮжһңжҸҗдҫӣпјү | Validate and normalize cache time (if provided)
      if (data.cacheTime !== undefined) {
        data.cacheTime = this.normalizeCacheTime(data.cacheTime);
      }

      // жӣҙж–°зәҝи·ҜдҝЎжҒҜ | Update line information
      const updatedLine: LineItem = {
        id: line.id,
        name: data.name !== undefined ? data.name : line.name,
        url: data.url !== undefined ? data.url : line.url,
        description: data.description !== undefined ? data.description : line.description,
        type: data.type !== undefined ? data.type : line.type,
        updateTime: Date.now(),
        createTime: line.createTime,
        sourceCount: data.sourceCount !== undefined ? data.sourceCount : line.sourceCount,
        enabled: data.enabled !== undefined ? data.enabled : line.enabled,
        current: data.current !== undefined ? data.current : line.current,
        cacheTime: data.cacheTime !== undefined ? data.cacheTime : line.cacheTime,
        responseTime: data.responseTime !== undefined ? data.responseTime : line.responseTime
      };

      // еҰӮжһңжӣҙж–°дәҶURLпјҢйңҖиҰҒйҮҚж–°з”ҹжҲҗID | If URL is updated, need to regenerate ID
      if (data.url && data.url !== line.url) {
        // йӘҢиҜҒж–°URL | Validate new URL
        if (!this.isValidUrl(data.url)) {
          return {
            success: false,
            message: 'ж— ж•Ҳзҡ„URLж јејҸ'
          };
        }

        // жЈҖжҹҘж–°URLжҳҜеҗҰе·Іеӯҳең?| Check if new URL already exists
        const newId = this.generateLineId(data.url);
        if (this.lines.has(newId) && newId !== lineId) {
          return {
            success: false,
            message: 'ж–°URLе·ІеӯҳеңЁзәҝи·?
          };
        }

        // д»Һж—§IDеҲ йҷӨ | Remove from old ID
        this.lines.delete(lineId);
        
        // з”Ёж–°IDж·»еҠ  | Add with new ID
        updatedLine.id = newId;
        this.lines.set(newId, updatedLine);
      } else {
        this.lines.set(lineId, updatedLine);
      }

      // дҝқеӯҳеҲ°жҢҒд№…еҢ–еӯҳеӮЁ | Save to persistent storage
      await this.saveLines();

      console.info(TAG + `: Updated line: ${updatedLine.name}`);
      return {
        success: true,
        message: 'зәҝи·Ҝжӣҙж–°жҲҗеҠҹ',
        data: updatedLine
      };
    } catch (error) {
      console.error(TAG + `: Failed to update line: ${error.message}`);
      return {
        success: false, 
        message: `жӣҙж–°зәҝи·ҜеӨұиҙҘ: ${error.message}`
      };
    }
  }

  /**
   * еҲ·ж–°зәҝи·ҜпјҲејәеҲ¶жӣҙж–°пјҢи·іиҝҮзј“еӯҳпј?| Refresh line (force update, skip cache)
   * @param lineId зәҝи·ҜID | Line ID
   */
  public async refreshLine(lineId: string): Promise<LineResult> {
    try {
      const line = this.lines.get(lineId);
      if (!line) {
        return {
          success: false,
          message: 'зәҝи·ҜдёҚеӯҳең?
        };
      }

      // ејәеҲ¶д»ҺURLеҠ иҪҪжңҖж–°й…ҚзҪ®пјҲи·іиҝҮзј“еӯҳпј?| Force load latest config from URL (skip cache)
      const startTime = Date.now();
      const configContent = await ConfigLoader.getInstance().loadFromUrl(line.url, line.cacheTime, true);
      const responseTime = Date.now() - startTime;
      
      // и§Јжһҗжәҗй…ҚзҪ?| Parse source config
      const sites = ConfigParser.getInstance().parseSites(configContent);
      
      // жӣҙж–°зәҝи·ҜдҝЎжҒҜ | Update line information
      line.sourceCount = sites.length;
      line.updateTime = Date.now();
      line.responseTime = responseTime;
      
      // еҰӮжһңжҳҜеҪ“еүҚзәҝи·ҜпјҢжӣҙж–°жә?| If it is current line, update sources
      if (line.current) {
        // е…ҲзҰҒз”ЁжүҖжңүеҪ“еүҚжәҗ | First disable all current sources
        await this.disableCurrentSources();
        
        // жіЁеҶҢж–°жәҗ | Register new sources
        await SiteManager.getInstance().registerSites(sites);
      }

      // дҝқеӯҳеҲ°жҢҒд№…еҢ–еӯҳеӮЁ | Save to persistent storage
      await this.saveLines();

      console.info(TAG + `: Refreshed line: ${line.name}, loaded ${sites.length} sources`);
      return {
        success: true,
        message: `зәҝи·ҜеҲ·ж–°жҲҗеҠҹпјҢе…ұ${sites.length}дёӘжәҗпјҢе“Қеә”ж—¶й—?{responseTime}ms`,
        data: {
          line,
          sites,
          responseTime
        }
      };
    } catch (error) {
      console.error(TAG + `: Failed to refresh line: ${error.message}`);
      return {
        success: false, 
        message: `еҲ·ж–°зәҝи·ҜеӨұиҙҘ: ${error.message}`
      };
    }
  }

  /**
   * еҲҮжҚўеҲ°жҢҮе®ҡзәҝи·?| Switch to specified line
   * @param lineId зәҝи·ҜID | Line ID
   */
  public async switchToLine(lineId: string): Promise<LineResult> {
    try {
      const line = this.lines.get(lineId);
      if (!line) {
        return {
          success: false,
          message: 'зәҝи·ҜдёҚеӯҳең?
        };
      }

      if (!line.enabled) {
        return {
          success: false,
          message: 'зәҝи·Ҝе·ІзҰҒз”?
        };
      }

      // зҰҒз”ЁеҪ“еүҚзәҝи·Ҝ | Disable current line
      await this.disableCurrentLine();

      // и®ҫзҪ®ж–°зҡ„еҪ“еүҚзәҝи·Ҝ | Set new current line
      line.current = true;
      
      // еҠ иҪҪзәҝи·Ҝй…ҚзҪ®пјҢдҪҝз”Ёзәҝи·Ҝй…ҚзҪ®зҡ„зј“еӯҳж—¶й—ҙ | Load line config, use line's cache time
      const configContent = await ConfigLoader.getInstance().loadFromUrl(line.url, line.cacheTime);
      const sites = ConfigParser.getInstance().parseSites(configContent);
      
      // жіЁеҶҢжә?| Register sources
      await SiteManager.getInstance().registerSites(sites);
      
      // дҝқеӯҳеҲ°жҢҒд№…еҢ–еӯҳеӮЁ | Save to persistent storage
      await this.saveLines();

      console.info(TAG + `: Switched to line: ${line.name}, loaded ${sites.length} sources`);
      return {
        success: true,
        message: `жҲҗеҠҹеҲҮжҚўеҲ°зәҝи·?${line.name}"`,
        data: sites
      };
    } catch (error) {
      console.error(TAG + `: Failed to switch line: ${error.message}`);
      return {
        success: false, 
        message: `еҲҮжҚўзәҝи·ҜеӨұиҙҘ: ${error.message}`
      };
    }
  }

  /**
   * жөӢиҜ•зәҝи·Ҝе“Қеә”йҖҹеәҰ | Test line response speed
   * @param lineId зәҝи·ҜID | Line ID
   * @param multiThread жҳҜеҗҰдҪҝз”ЁеӨҡзәҝзЁ?| Whether to use multi-thread
   * @param timeout и¶…ж—¶ж—¶й—ҙпјҲжҜ«з§’пјү | Timeout time (milliseconds)
   */
  public async testLineResponse(lineId: string, multiThread: boolean = false, timeout: number = 20000): Promise<LineResponseResult> {
    const line = this.lines.get(lineId);
    if (!line) {
      return {
        lineId,
        lineName: '',
        responseTime: 0,
        success: false,
        error: 'зәҝи·ҜдёҚеӯҳең?
      };
    }

    try {
      const startTime = Date.now();
      
      // жөӢиҜ•зәҝи·Ҝе“Қеә”йҖҹеәҰ | Test line response speed
      const configContent = await ConfigLoader.getInstance().loadFromUrl(line.url);
      const responseTime = Date.now() - startTime;
      
      // и§Јжһҗжә?| Parse sources
      const sites = ConfigParser.getInstance().parseSites(configContent);
      
      // жӣҙж–°зәҝи·Ҝе“Қеә”ж—¶й—ҙ | Update line response time
      line.responseTime = responseTime;
      await this.saveLines();
      
      return {
        lineId: line.id,
        lineName: line.name,
        responseTime,
        success: true
      };
    } catch (error) {
      console.error(TAG + `: Failed to test line response: ${error.message}`);
      return {
        lineId: line.id, 
        lineName: line.name,
        responseTime: 0,
        success: false,
        error: error.message
      };
    }
  }

  /**
   * жөӢиҜ•зәҝи·ҜдёӢжүҖжңүжәҗзҡ„е“Қеә”йҖҹеәҰ | Test response speed of all sources under line
   * @param lineId зәҝи·ҜID | Line ID
   * @param multiThread жҳҜеҗҰдҪҝз”ЁеӨҡзәҝзЁ?| Whether to use multi-thread
   * @param timeout и¶…ж—¶ж—¶й—ҙпјҲжҜ«з§’пјү | Timeout time (milliseconds)
   */
  public async testSourceResponses(lineId: string, multiThread: boolean = false, timeout: number = 15000): Promise<SourceResponseResult[]> {
    const line = this.lines.get(lineId);
    if (!line) {
      return [];
    }

    try {
      // еҠ иҪҪзәҝи·Ҝй…ҚзҪ® | Load line config
      const configContent = await ConfigLoader.getInstance().loadFromUrl(line.url);
      const sites = ConfigParser.getInstance().parseSites(configContent);
      
      const results: SourceResponseResult[] = [];
      
      if (multiThread) {
        // еӨҡзәҝзЁӢжЁЎеј?| Multi-thread mode
        const testPromises = sites.map(async (site) => {
          try {
            const startTime = Date.now();
            
            // еҲӣе»әHTTPиҜ·жұӮеҜ№иұЎ | Create HTTP request object
            const httpRequest = http.createHttp();
            
            // жөӢиҜ•жәҗURL | Test source URL
            const response = await httpRequest.request(site.api, {
              method: http.RequestMethod.GET,
              header: {
                'User-Agent': 'RayTV-HarmonyOS',
                'Accept': '*/*'
              }
            });
            
            // йҮҠж”ҫиө„жәҗ | Release resources
            httpRequest.destroy();
            
            const responseTime = Date.now() - startTime;
            
            return {
              sourceId: site.key,
              sourceName: site.name,
              responseTime,
              success: response.result?.ret?.code === 0 || response.responseCode >= 200 && response.responseCode < 300
            };
          } catch (error) {
            return {
              sourceId: site.key,
              sourceName: site.name,
              responseTime: 0,
              success: false,
              error: String(error)
            };
          }
        });
        
        // зӯүеҫ…жүҖжңүжөӢиҜ•е®ҢжҲ?| Wait for all tests to complete
        const threadResults = await Promise.all(testPromises);
        // дҪҝз”ЁеҫӘзҺҜжӣҝд»Јжү©еұ•иҝҗз®—з¬?        for (let i = 0; i < threadResults.length; i++) {
          results.push(threadResults[i]);
        }
      } else {
        // еҚ•зәҝзЁӢжЁЎеј?| Single-thread mode
        for (const site of sites) {
          try {
            const startTime = Date.now();
            
            // еҲӣе»әHTTPиҜ·жұӮеҜ№иұЎ | Create HTTP request object
            const httpRequest = http.createHttp();
            
            // жөӢиҜ•жәҗURL | Test source URL
            const response = await httpRequest.request(site.api, {
              method: http.RequestMethod.GET,
              header: {
                'User-Agent': 'RayTV-HarmonyOS',
                'Accept': '*/*'
              }
            });
            
            // йҮҠж”ҫиө„жәҗ | Release resources
            httpRequest.destroy();
            
            const responseTime = Date.now() - startTime;
            
            results.push({
              sourceId: site.key,
              sourceName: site.name,
              responseTime,
              success: response.result?.ret?.code === 0 || response.responseCode >= 200 && response.responseCode < 300
            });
          } catch (error) {
            results.push({
              sourceId: site.key,
              sourceName: site.name,
              responseTime: 0,
              success: false,
              error: String(error)
            });
          }
        }
      }
      
      return results;
    } catch (error) {
      console.error(TAG + ': Failed to test source responses', error);
      return [];
    }
  }

  /**
   * зҰҒз”ЁеҪ“еүҚзәҝи·Ҝ | Disable current line
   */
  private async disableCurrentLine(): Promise<void> {
    // зҰҒз”ЁжүҖжңүжәҗ | Disable all sources
    await this.disableCurrentSources();
    
    // йҮҚзҪ®жүҖжңүзәҝи·Ҝзҡ„currentзҠ¶жҖ?| Reset current status of all lines
    for (const line of this.lines.values()) {
      line.current = false;
    }
  }

  /**
   * зҰҒз”ЁеҪ“еүҚжүҖжңүжәҗ | Disable all current sources
   */
  private async disableCurrentSources(): Promise<void> {
    const sites = SiteManager.getInstance().getAllSites();
    for (const site of sites) {
      await SiteManager.getInstance().setSiteEnabled(site.key, false);
    }
  }

  /**
   * жөӢиҜ•зәҝи·ҜURL | Test line URL
   * @param url зәҝи·ҜURL | Line URL
   */
  public async testLineUrl(url: string): Promise<LineResult> {
    try {
      console.info(TAG + `: Testing line URL: ${url}`);
      
      const startTime = Date.now();
      // еҠ иҪҪй…ҚзҪ®пјҢдҪҝз”Ёй»ҳи®Өзј“еӯҳж—¶й—ҙпјҢдёҚејәеҲ¶жӣҙж–?| Load config, use default cache time, not force update
      const configContent = await ConfigLoader.getInstance().loadFromUrl(url, this.defaultCacheHours);
      const responseTime = Date.now() - startTime;
      
      // и§Јжһҗжә?| Parse sources
      const sites = ConfigParser.getInstance().parseSites(configContent);
      
      // йӘҢиҜҒжәҗж•°йҮ?| Validate source count
      if (sites.length === 0) {
        return {
          success: false,
          message: 'й…ҚзҪ®ж–Үд»¶дёӯжңӘжүҫеҲ°жңүж•Ҳжә?
        };
      }
      
      return {
        success: true,
        message: `URLи®ҝй—®жҲҗеҠҹпјҢеҸ‘зҺ?{sites.length}дёӘжәҗпјҢе“Қеә”ж—¶й—?{responseTime}ms`,
        data: { sites, responseTime }
      };
    } catch (error) {
      console.error(TAG + ': Failed to test line URL', error);
      return {
        success: false,
        message: `URLжөӢиҜ•еӨұиҙҘ: ${error.message}`
      };
    }
  }

  /**
   * иҺ·еҸ–жүҖжңүзәҝи·?| Get all lines
   */
  public getAllLines(): LineItem[] {
    return Array.from(this.lines.values());
  }

  /**
   * иҺ·еҸ–зәҝи·ҜиҜҰжғ… | Get line details
   * @param lineId зәҝи·ҜID | Line ID
   */
  public getLine(lineId: string): LineItem | undefined {
    return this.lines.get(lineId);
  }

  /**
   * иҺ·еҸ–еҪ“еүҚдҪҝз”Ёзҡ„зәҝи·?| Get current line
   */
  public getCurrentLine(): LineItem | undefined {
    return Array.from(this.lines.values()).find(line => line.current);
  }

  /**
   * жЈҖжҹҘжҳҜеҗҰжңүеҸҜз”Ёзәҝи·Ҝ | Check if there are available lines
   */
  public hasAvailableLines(): boolean {
    return Array.from(this.lines.values()).some(line => line.enabled);
  }

  /**
   * з”ҹжҲҗзәҝи·ҜID | Generate line ID
   * @param url зәҝи·ҜURL | Line URL
   */
  private generateLineId(url: string): string {
    // з®ҖеҚ•зҡ„URLе“ҲеёҢдҪңдёәзәҝи·ҜID | Simple URL hash as line ID
    let hash = 0;
    for (let i = 0; i < url.length; i++) {
      const char = url.charCodeAt(i);
      hash = ((hash << 5) - hash) + char;
      hash = hash & hash;
    }
    return `line_${Math.abs(hash).toString(36)}`;
  }

  /**
   * йӘҢиҜҒURLж јејҸ | Validate URL format
   * @param url URLеӯ—з¬Ұдё?| URL string
   */
  private isValidUrl(url: string): boolean {
    try {
      new URL(url);
      return true;
    } catch {
      // з®ҖеҚ•зҡ„URLж јејҸжЈҖжҹҘдҪңдёәеӨҮз”?| Simple URL format check as fallback
      return /^https?:\/\/.+/.test(url);
    }
  }

  /**
   * и§„иҢғеҢ–зј“еӯҳж—¶й—?| Normalize cache time
   * @param hours зј“еӯҳж—¶й—ҙпјҲе°Ҹж—¶пјү | Cache time (hours)
   */
  private normalizeCacheTime(hours?: number): number {
    if (hours === undefined) {
      return this.defaultCacheHours;
    }
    return Math.max(this.minCacheHours, Math.min(this.maxCacheHours, Math.floor(hours)));
  }

  /**
   * дҝқеӯҳзәҝи·ҜеҲ—иЎЁеҲ°жҢҒд№…еҢ–еӯҳеӮЁ | Save line list to persistent storage
   */
  private async saveLines(): Promise<void> {
    try {
      const lines = Array.from(this.lines.values());
      console.info(TAG + `: Saving ${lines.length} lines`);
      
      // жү№йҮҸдҝқеӯҳзәҝи·Ҝ | Batch save lines
      await new LineDao().saveAll(lines);
    } catch (error) {
      console.error(TAG + `: Failed to save lines: ${error.message}`);
      // дҝқеӯҳеӨұиҙҘдёҚеҪұе“Қдё»иҰҒеҠҹиғ?| Save failure does not affect main functionality
    }
  }

  /**
   * д»ҺжҢҒд№…еҢ–еӯҳеӮЁеҠ иҪҪзәҝи·ҜеҲ—иЎЁ | Load line list from persistent storage
   */
  private async loadLines(): Promise<void> {
    try {
      console.info(TAG + ': Loading lines from storage');
      
      // д»Һж•°жҚ®еә“еҠ иҪҪзәҝи·Ҝ | Load lines from database
      const lines = await new LineDao().getAll();
      
      // жё…з©әзҺ°жңүзәҝи·Ҝ | Clear existing lines
      this.lines.clear();
      
      // ж·»еҠ еҲ°еҶ…еӯ?| Add to memory
      lines.forEach(line => {
        this.lines.set(line.id, line);
      });
      
      console.info(TAG + `: Loaded ${lines.length} lines from storage`);
    } catch (error) {
      console.error(TAG + `: Failed to load lines: ${error.message}`);
    }
  }
}

export function getLineManager(): LineManager {
  return LineManager.getInstance();
}
