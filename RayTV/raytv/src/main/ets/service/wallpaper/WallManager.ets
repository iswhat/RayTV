  }
  
  /**
   * иҺ·еҸ–еҪ“еүҚеЈҒзәё Get current wallpaper
   */
  public getCurrentWallpaper(): WallpaperInfo | null {
    return this.isEnabled ? this.currentWallpaper : null;
  }
  
  /**
   * жё…йҷӨеҪ“еүҚеЈҒзәё Clear current wallpaper
   */
