  /**
   * д»ҺURIиҺ·еҸ–еЈҒзәёеҗҚз§° Get wallpaper name from URI
   */
  private getWallpaperName(uri: string): string {
    try {
      // д»ҺURIдёӯжҸҗеҸ–ж–Үд»¶еҗҚ Extract filename from URI
      const parts = uri.split('/');
