/**
 * дё»ViewModel | Main ViewModel
 * иҙҹиҙЈеә”з”Ёзҡ„дё»иҰҒзҠ¶жҖҒз®ЎзҗҶе’Ңж•°жҚ®иҪ¬жҚў
 */
import { BaseViewModel } from './BaseViewModel';
import { AppEvents } from '../../common/event/EventBus';
import Logger from '../../common/util/Logger';

// и§ҶеӣҫзҠ¶жҖҒжҺҘеҸЈ | View state interface
interface ViewState {
  selectedTab: string;
  featuredMedia: MediaItem[];
  categories: CategoryItem[];
  isLoading: boolean;
  error: string | null;
  searchQuery: string;
  networkStatus: NetworkStatus;
}

// еӘ’дҪ“йЎ№жҺҘеҸЈ | Media item interface
interface MediaItem {
  id: string;
  title: string;
  coverUrl: string;
  type: 'vod' | 'live' | 'series';
  rating?: number;
  duration?: number;
}

// еҲҶзұ»йЎ№жҺҘеҸЈ | Category item interface
interface CategoryItem {
  id: string;
  name: string;
  icon?: string;
}

// зҪ‘з»ңзҠ¶жҖҒ | Network status
interface NetworkStatus {
  isConnected: boolean;
  type: 'wifi' | 'mobile' | 'ethernet' | 'unknown';
  strength?: number;
}

/**
 * дё»ViewModelзұ» | Main ViewModel class
 */
export class MainViewModel extends BaseViewModel {
  // и§ҶеӣҫзҠ¶жҖҒ | View state
  private _state: ViewState = {
    selectedTab: 'vod',
    featuredMedia: [],
    categories: [],
    isLoading: false,
    error: null,
    searchQuery: '',
    networkStatus: {
      isConnected: true,
      type: 'unknown'
    }
  };

  // жңҚеҠЎе®һдҫӢ | Service instances
  private mediaService: any;
  private configService: any;
  private networkService: any;

  /**
   * жһ„йҖ еҮҪж•° | Constructor
   */
  constructor() {
    super();
    this.initializeServices();
  }

  /**
   * еҲқе§ӢеҢ–жңҚеҠЎ | Initialize services
   */
  private initializeServices(): void {
    try {
      // е°қиҜ•и§ЈжһҗжңҚеҠЎ | Try to resolve services
      if (this.hasService('mediaService')) {
        this.mediaService = this.resolve('mediaService');
      }
      if (this.hasService('configService')) {
        this.configService = this.resolve('configService');
      }
      if (this.hasService('networkService')) {
        this.networkService = this.resolve('networkService');
      }
    } catch (error) {
      this.logger.error('Failed to initialize services:', error);
    }
  }

  /**
   * и®ҫзҪ®дәӢд»¶и®ўйҳ… | Set up event subscriptions
   */
  protected setupSubscriptions(): void {
    // зӣ‘еҗ¬й…ҚзҪ®еҸҳеҢ– | Listen for config changes
    this.subscribe(AppEvents.CONFIG_SOURCE_UPDATED, () => {
      this.refreshContent();
    });

    // зӣ‘еҗ¬зҪ‘з»ңзҠ¶жҖҒеҸҳеҢ– | Listen for network status changes
    this.subscribe(AppEvents.NETWORK_STATUS_CHANGE, (status: NetworkStatus) => {
      this.handleNetworkChange(status);
    });

    // зӣ‘еҗ¬еҶ…е®№иҒҡеҗҲе®ҢжҲҗ | Listen for content aggregation complete
    this.subscribe(AppEvents.CONTENT_AGGREGATION_COMPLETE, () => {
      this.refreshContent();
    });

    // зӣ‘еҗ¬еҶ…е®№иҒҡеҗҲй”ҷиҜҜ | Listen for content aggregation error
    this.subscribe(AppEvents.CONTENT_AGGREGATION_ERROR, (error: string) => {
      this.setState(prev => ({
        ...prev,
        error,
        isLoading: false
      }));
    });
  }

  /**
   * иҺ·еҸ–зҠ¶жҖҒ | Get state
   */
  public get state(): ViewState {
    return this._state;
  }

  /**
   * и®ҫзҪ®зҠ¶жҖҒ | Set state
   * @param updater зҠ¶жҖҒжӣҙж–°еҮҪж•° | State updater function
   */
  public setState(updater: (prevState: ViewState) => ViewState): void {
    this._state = updater(this._state);
    this.emit('main:stateChanged', this._state);
  }

  /**
   * еҠ иҪҪеҲқе§Ӣж•°жҚ® | Load initial data
   */
  public async loadInitialData(): Promise<void> {
    this.setState(prev => ({ ...prev, isLoading: true, error: null }));

    try {
      await Promise.all([
        this.loadCategories(),
        this.loadFeaturedContent()
      ]);
    } catch (error) {
      this.setState(prev => ({
        ...prev,
        error: error instanceof Error ? error.message : 'Failed to load initial data',
        isLoading: false
      }));
    }
  }

  /**
   * еҲ·ж–°еҶ…е®№ | Refresh content
   */
  public async refreshContent(): Promise<void> {
    this.setState(prev => ({ ...prev, isLoading: true, error: null }));

    try {
      await this.loadFeaturedContent();
    } catch (error) {
      this.setState(prev => ({
        ...prev,
        error: error instanceof Error ? error.message : 'Failed to refresh content',
        isLoading: false
      }));
    }
  }

  /**
   * еҠ иҪҪеҲҶзұ» | Load categories
   */
  private async loadCategories(): Promise<void> {
    try {
      if (this.configService) {
        const categories = await this.configService.getCategories();
        this.setState(prev => ({
          ...prev,
          categories
        }));
      } else {
        // дҪҝз”Ёй»ҳи®ӨеҲҶзұ» | Use default categories
        this.setState(prev => ({
          ...prev,
          categories: [
            { id: 'all', name: 'е…ЁйғЁ' },
            { id: 'movie', name: 'з”өеҪұ' },
            { id: 'tv', name: 'з”өи§Ҷеү§' },
            { id: 'anime', name: 'еҠЁжј«' },
            { id: 'variety', name: 'з»јиүә' }
          ]
        }));
      }
    } catch (error) {
      this.logger.error('Failed to load categories:', error);
      // дҪҝз”Ёй»ҳи®ӨеҲҶзұ» | Use default categories
      this.setState(prev => ({
        ...prev,
        categories: [
          { id: 'all', name: 'е…ЁйғЁ' },
          { id: 'movie', name: 'з”өеҪұ' },
          { id: 'tv', name: 'з”өи§Ҷеү§' },
          { id: 'anime', name: 'еҠЁжј«' },
          { id: 'variety', name: 'з»јиүә' }
        ]
      }));
    }
  }

  /**
   * еҠ иҪҪжҺЁиҚҗеҶ…е®№ | Load featured content
   */
  private async loadFeaturedContent(): Promise<void> {
    try {
      if (this.mediaService) {
        const content = await this.mediaService.getRecommendedContent();
        this.setState(prev => ({
          ...prev,
          featuredMedia: content,
          isLoading: false
        }));
      } else {
        // дҪҝз”ЁжЁЎжӢҹж•°жҚ® | Use mock data
        this.setState(prev => ({
          ...prev,
          featuredMedia: this.getMockMediaItems(),
          isLoading: false
        }));
      }
    } catch (error) {
      this.logger.error('Failed to load featured content:', error);
      // дҪҝз”ЁжЁЎжӢҹж•°жҚ® | Use mock data
      this.setState(prev => ({
        ...prev,
        featuredMedia: this.getMockMediaItems(),
        isLoading: false
      }));
    }
  }

  /**
   * йҖүжӢ©ж ҮзӯҫйЎө | Select tab
   * @param tab ж ҮзӯҫйЎөеҗҚз§° | Tab name
   */
  public selectTab(tab: string): void {
    this.setState(prev => ({
      ...prev,
      selectedTab: tab
    }));

    if (tab === 'vod') {
      this.loadFeaturedContent();
    }
  }

  /**
   * и®ҫзҪ®жҗңзҙўжҹҘиҜў | Set search query
   * @param query жҗңзҙўжҹҘиҜў | Search query
   */
  public setSearchQuery(query: string): void {
    this.setState(prev => ({
      ...prev,
      searchQuery: query
    }));
  }

  /**
   * еӨ„зҗҶзҪ‘з»ңзҠ¶жҖҒеҸҳеҢ– | Handle network status change
   * @param status зҪ‘з»ңзҠ¶жҖҒ | Network status
   */
  private handleNetworkChange(status: NetworkStatus): void {
    this.setState(prev => ({
      ...prev,
      networkStatus: status
    }));

    // еҰӮжһңзҪ‘з»ңйҮҚж–°иҝһжҺҘдё”жңүй”ҷиҜҜпјҢе°қиҜ•еҲ·ж–°еҶ…е®№ | If network reconnects and there's an error, try to refresh content
    if (status.isConnected && this._state.error) {
      this.refreshContent();
    }
  }

  /**
   * иҺ·еҸ–жЁЎжӢҹеӘ’дҪ“ж•°жҚ® | Get mock media items
   */
  private getMockMediaItems(): MediaItem[] {
    return [
      {
        id: '1',
        title: 'еӨҚд»ҮиҖ…иҒ”зӣҹ4пјҡз»ҲеұҖд№ӢжҲҳ',
        coverUrl: 'https://example.com/avengers4.jpg',
        type: 'movie',
        rating: 8.5,
        duration: 181
      },
      {
        id: '2',
        title: 'жқғеҠӣзҡ„жёёжҲҸ з¬¬е…«еӯЈ',
        coverUrl: 'https://example.com/got8.jpg',
        type: 'series',
        rating: 7.5
      },
      {
        id: '3',
        title: 'иҝӣеҮ»зҡ„е·Ёдәә жңҖз»ҲеӯЈ',
        coverUrl: 'https://example.com/aot.jpg',
        type: 'anime',
        rating: 9.0
      },
      {
        id: '4',
        title: 'еҘ”и·‘еҗ§е…„ејҹ з¬¬д№қеӯЈ',
        coverUrl: 'https://example.com/run.jpg',
        type: 'variety',
        rating: 6.8
      },
      {
        id: '5',
        title: 'жөҒжөӘең°зҗғ2',
        coverUrl: 'https://example.com/thewanderingearth2.jpg',
        type: 'movie',
        rating: 8.3,
        duration: 173
      }
    ];
  }

  /**
   * жё…зҗҶиө„жәҗ | Clean up resources
   */
  public override dispose(): void {
    super.dispose();
    this.logger.info('MainViewModel disposed');
  }
}
